
@model SaleManamentSystem.Models.ProductEntity

<div class="modal-header bg-info text-white">
    <h5 class="modal-title fw-bold">CHI TIẾT SẢN PHẨM</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body">
    <div class="form-group mb-3">
        <label class="fw-bold">Mã sản phẩm</label>
        @Html.TextBoxFor(m => m.ProductID, new { @class = "form-control", @disabled = "disabled" })
    </div>

    <div class="form-group mb-3">
        <label class="fw-bold">Tên sản phẩm</label>
        @Html.TextBoxFor(m => m.ProductName, new { @class = "form-control", @disabled = "disabled" })
    </div>

    <div class="form-group mb-3">
        <label class="fw-bold">Giá bán hiện tại</label>
        <input type="text" class="form-control" disabled="disabled"
               value="@Model.Price.ToString("N0") VNĐ" />
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Đóng cửa sổ</button>
</div>