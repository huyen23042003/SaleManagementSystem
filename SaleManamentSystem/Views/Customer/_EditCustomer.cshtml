@model SaleManamentSystem.Models.CustomerEntity

<div class="modal-header bg-warning text-dark">
    <h5 class="modal-title fw-bold">CẬP NHẬT KHÁCH HÀNG</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

@using (Html.BeginForm("EditCustomer", "Customer", FormMethod.Post, new { id = "editForm" }))
{
    <div class="modal-body">
        <div class="form-group mb-3">
            <label class="fw-bold">Mã khách hàng</label>
            <input type="text" class="form-control bg-light"
                   value="@Model.CustomerID"
                   readonly
                   style="cursor: not-allowed;"
                   title="Không thể sửa mã khách hàng" />

            @Html.HiddenFor(m => m.CustomerID)
        </div>

        <div class="form-group mb-3">
            <label class="fw-bold">Tên khách hàng</label>
            @Html.TextBoxFor(m => m.CustomerName, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.CustomerName, "", new { @class = "text-danger" })
        </div>
        <div class="form-group mb-3">
            <label class="fw-bold">Số điện thoại</label>
            @Html.TextBoxFor(m => m.Phone, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger" })
        </div>

    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Thoát</button>
        <button type="submit" class="btn btn-warning text-dark fw-bold">Lưu thay đổi</button>
    </div>
}


<script>
    $(document).ready(function () {
        $.validator.unobtrusive.parse("#editForm");
    });
</script>