
@model SaleManamentSystem.Models.CustomerEntity

<div class="modal-header bg-info text-white">
    <h5 class="modal-title fw-bold">CHI TIẾT KHÁCH HÀNG</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body">
    <div class="form-group mb-3">
        <label class="fw-bold">Mã khách hàng</label>
        @Html.TextBoxFor(m => m.CustomerID, new { @class = "form-control", @disabled = "disabled" })
    </div>

    <div class="form-group mb-3">
        <label class="fw-bold">Tên khách hàng</label>
        @Html.TextBoxFor(m => m.CustomerName, new { @class = "form-control", @disabled = "disabled" })
    </div>

    <div class="form-group mb-3">
        <label class="fw-bold">Số điện thoại</label>
        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", @disabled = "disabled" })
    </div>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Đóng cửa sổ</button>
</div>
