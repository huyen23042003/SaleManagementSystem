@model IEnumerable<SaleManamentSystem.Models.InvoiceEntity>
@{
    ViewBag.Title = "DANH MỤC HÓA ĐƠN";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">@ViewBag.Title</h4>
            <button class="btn btn-light btn-sm" onclick="openPopup('/Invoice/AddInvoice')">
                <b>+ Thêm mới</b>
            </button>
        </div>
        <div class="card-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.InvoiceID)</th>
                        <th>@Html.DisplayNameFor(m => m.CustomerID)</th>
                        <th>@Html.DisplayNameFor(m => m.InvoiceDate)</th>
                        <th>@Html.DisplayNameFor(m => m.TotalPrice)</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.InvoiceID</td>
                            <td>@item.CustomerID</td>
                            <td>@item.InvoiceDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.TotalPrice.ToString("N0")</td>
                            <td class="text-center">
                                <button class="btn btn-info btn-sm" onclick="openPopup('/Invoice/Details?invoiceID=@item.InvoiceID')">Xem</button>
                                <button class="btn btn-warning btn-sm" onclick="openPopup('/Invoice/EditInvoice?invoiceID=@item.InvoiceID')">Sửa</button>

                                @using (Html.BeginForm("DeleteInvoice", "Invoice", FormMethod.Post, new { @class = "d-inline" }))
                                {
                                    @Html.Hidden("invoiceID", item.InvoiceID)
                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Bạn có muốn xóa hóa đơn [@item.InvoiceID] không?');">
                                        Xóa
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="actionModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content" id="modalBodyContent">
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
    <script>
        var isAdded = false;

        function openPopup(url) {
            isAdded = false;
            $.get(url, function (data) {
                $('#modalBodyContent').html(data);
                $('#actionModal').modal('show');
            });
        }

        function submitInvoice(action) {
            var form = $('#invoiceForm');

            if ($("#InvoiceID").val().trim() === "" || $("#CustomerID").val() === "") {
                alert("Vui lòng nhập đầy đủ Mã hóa đơn và Khách hàng!");
                return false;
            }

            var rows = $("#detailTable tbody tr");
            if (rows.length === 0) {
                alert("Hóa đơn chưa có sản phẩm!");
                return false;
            }

            var isValidProducts = true;
            rows.each(function (i, tr) {
                var productId = $(tr).find('.prod-select').val();
                if (!productId || productId === "") {
                    alert("Dòng số " + (i + 1) + " chưa chọn sản phẩm. Vui lòng kiểm tra lại!");
                    $(tr).find('.prod-select').focus(); 
                    isValidProducts = false;
                    return false; 
                }

                $(tr).find('select, input').each(function () {
                    var name = $(this).attr('name');
                    if (name) {
                        var newName = name.replace(/\[\d+\]/, '[' + i + ']');
                        $(this).attr('name', newName);
                    }
                });
            });

            if (!isValidProducts) return false; 

            var formData = form.serialize() + "&submitButton=" + action;
            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: formData,
                success: function (res) {
                    if (res.indexOf("window.location.reload()") > -1) {
                        location.reload();
                    } else {
                        $('#modalBodyContent').html(res);
                        isAdded = true;
                        $('.modal-body').animate({ scrollTop: 0 }, 'fast');
                    }
                },
                error: function (xhr) {
                    alert("Có lỗi xảy ra (Lỗi 500 hoặc kết nối).");
                }
            });
        }
        $(document).ready(function () {
            $('#actionModal').on('hidden.bs.modal', function () {
                if (isAdded) {
                    location.reload();
                }
            });
        });
    </script>
}


