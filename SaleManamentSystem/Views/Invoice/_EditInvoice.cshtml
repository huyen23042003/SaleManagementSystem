@model SaleManamentSystem.Models.InvoiceEntity
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<div class="modal-header bg-warning text-dark">
    <h5 class="modal-title fw-bold">CHỈNH SỬA HÓA ĐƠN: @Model.InvoiceID</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

@using (Html.BeginForm("EditInvoice", "Invoice", FormMethod.Post, new { id = "editInvoiceForm" }))
{
    <div class="modal-body" style="max-height: 500px; overflow-y: auto;">
        @Html.HiddenFor(m => m.InvoiceID)
        @Html.HiddenFor(m => m.InvoiceDate)
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Khách hàng</label>
                @Html.DropDownListFor(m => m.CustomerID, (IEnumerable<SelectListItem>)ViewBag.Customers, new { @class = "form-select", id = "editCustomerID" })
            </div>
            <div class="col-md-6 mb-3 text-end">
                <label class="fw-bold d-block">Ngày lập</label>
                <span class="badge bg-light text-dark border">@Model.InvoiceDate.ToString("dd/MM/yyyy")</span>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="fw-bold mb-0">CHI TIẾT MẶT HÀNG</h6>
            <button type="button" class="btn btn-sm btn-success" onclick="addNewRowEdit()">+ Thêm dòng</button>
        </div>

        <table class="table table-bordered table-sm" id="editDetailTable">
            <thead class="table-light text-center">
                <tr>
                    <th style="width: 40%">Sản phẩm</th>
                    <th style="width: 20%">Đơn giá</th>
                    <th style="width: 15%">SL</th>
                    <th style="width: 20%">Thành tiền</th>
                    <th style="width: 5%"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.InvoiceDetails != null)
                {
                    for (int i = 0; i < Model.InvoiceDetails.Count; i++)
                    {
                        <tr>
                            <td>
                                @Html.DropDownListFor(m => m.InvoiceDetails[i].ProductID,
                                    new SelectList(ViewBag.Products, "ProductID", "ProductName", Model.InvoiceDetails[i].ProductID),
                                    new { @class = "form-select form-select-sm prod-select", onchange = "updateRowPrice(this)" })
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm unit-price" readonly
                                       value="@Model.InvoiceDetails[i].Price.ToString("N0")"
                                       data-raw="@Model.InvoiceDetails[i].Price" />
                            </td>
                            <td>
                                @Html.TextBoxFor(m => m.InvoiceDetails[i].Quantity,
                                    new { @class = "form-control form-control-sm qty-input", type = "number", min = "1", onchange = "calcRow(this)" })
                            </td>
                            <td class="text-end fw-bold">
                                <span class="row-total-text">@Model.InvoiceDetails[i].TotalPrice.ToString("N0")</span>
                                @Html.HiddenFor(m => m.InvoiceDetails[i].TotalPrice, new { @class = "row-total-value" })
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn btn-link text-danger p-0" onclick="removeRow(this)">X</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <div class="text-end mt-3 border-top pt-2">
            <span class="fw-bold me-2">TỔNG CỘNG:</span>
            <span id="spanTotalEdit" class="text-danger fw-bold h5">@Model.TotalPrice.ToString("N0")</span>
            @Html.HiddenFor(m => m.TotalPrice, new { id = "hdTotalPriceEdit" })
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        <button type="button" onclick="submitEditInvoice('Save')" class="btn btn-primary">Cập nhật thay đổi</button>
    </div>
}

<script>
    (function initEditScript() {
        if (window.jQuery) {
            var productData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Products));

            // 1. Hàm thêm dòng mới
            window.addNewRowEdit = function() {
                var index = $("#editDetailTable tbody tr").length;
                var options = `<option value="">-- Chọn --</option>`;
                productData.forEach(function(p) {
                    options += `<option value="${p.ProductID}" data-price="${p.Price}">${p.ProductName}</option>`;
                });

                var row = `
                <tr>
                    <td>
                        <select name="InvoiceDetails[${index}].ProductID" class="form-select form-select-sm prod-select" onchange="updateRowPrice(this)">
                            ${options}
                        </select>
                    </td>
                    <td><input type="text" class="form-control form-control-sm unit-price" readonly /></td>
                    <td><input type="number" name="InvoiceDetails[${index}].Quantity" class="form-control form-control-sm qty-input" value="1" min="1" onchange="calcRow(this)" /></td>
                    <td class="text-end fw-bold">
                        <span class="row-total-text">0</span>
                        <input type="hidden" name="InvoiceDetails[${index}].TotalPrice" class="row-total-value" value="0" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-link text-danger p-0" onclick="removeRow(this)">X</button>
                    </td>
                </tr>`;
                $("#editDetailTable tbody").append(row);
            };

            // 2. Hàm XÓA DÒNG (Đã thêm logic chặn dòng cuối)
            window.removeRow = function (btn) {
                var rowCount = $("#editDetailTable tbody tr").length;

                if (rowCount <= 1) {
                    alert("Hóa đơn phải có ít nhất 1 mặt hàng!");
                    return;
                }

                $(btn).closest('tr').remove();

                // Đánh lại số thứ tự index để gửi form chính xác
                $("#editDetailTable tbody tr").each(function (index, tr) {
                    $(tr).find('select, input').each(function () {
                        var name = $(this).attr('name');
                        if (name) {
                            var newName = name.replace(/\[\d+\]/, '[' + index + ']');
                            $(this).attr('name', newName);
                        }
                    });
                });
                calcGrandTotalEdit();
            };

            // 3. Các hàm tính toán giữ nguyên nhưng đảm bảo gọi đúng tên
            window.updateRowPrice = function(select) {
                var option = $(select).find(':selected');
                var price = parseFloat(option.data('price')) || 0;
                var row = $(select).closest('tr');
                row.find('.unit-price').val(new Intl.NumberFormat().format(price)).data('raw', price);
                calcRow(select);
            };

            window.calcRow = function(el) {
                var row = $(el).closest('tr');
                var price = parseFloat(row.find('.unit-price').data('raw')) || 0;
                var qty = parseInt(row.find('.qty-input').val()) || 0;
                var total = price * qty;
                row.find('.row-total-text').text(new Intl.NumberFormat().format(total));
                row.find('.row-total-value').val(total);
                calcGrandTotalEdit();
            };

            window.calcGrandTotalEdit = function() {
                var grandTotal = 0;
                $("#editDetailTable .row-total-value").each(function () {
                    grandTotal += parseFloat($(this).val()) || 0;
                });
                $("#spanTotalEdit").text(new Intl.NumberFormat().format(grandTotal));
                $("#hdTotalPriceEdit").val(grandTotal);
            };

            window.submitEditInvoice = function () {
                var form = $('#editInvoiceForm');
                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function (response) {
                        if (response.indexOf("window.location.reload") > -1) {
                            location.reload();
                        } else {
                            $('.modal-content').html(response);
                        }
                    }
                });
            };

        } else {
            setTimeout(initEditScript, 50);
        }
    })();
</script>